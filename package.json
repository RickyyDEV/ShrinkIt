    "@vitejs/plugin-rsc": "^0.5.22",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "prisma": "^7.7.0",
    "react-server-dom-webpack": "^19.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vinext": "0.0.39",
    "vite": "^8.0.7",
